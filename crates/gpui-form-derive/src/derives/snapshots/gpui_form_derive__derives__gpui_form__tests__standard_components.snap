#[derive(Clone, Debug, ::koruma::Koruma)]
pub struct StandardFormFormValueHolder {
    #[koruma(koruma_collection::general::RequiredValidation::<Option<_>>)]
    pub title: Option<String>,
    pub count: Option<i64>,
    pub is_admin: bool,
    pub is_active: Option<bool>,
    pub availability: chrono::NaiveDate,
}
impl Default for StandardFormFormValueHolder {
    fn default() -> Self {
        Self {
            title: None,
            count: None,
            is_admin: Default::default(),
            is_active: Default::default(),
            availability: Default::default(),
        }
    }
}
impl From<StandardForm> for StandardFormFormValueHolder {
    fn from(from: StandardForm) -> Self {
        Self {
            title: Some(from.title),
            count: from.count,
            is_admin: from.is_admin,
            is_active: from.is_active,
            availability: from.availability,
        }
    }
}
impl From<StandardFormFormValueHolder> for StandardForm {
    fn from(from: StandardFormFormValueHolder) -> Self {
        Self {
            title: from.title.unwrap_or_default(),
            count: from.count,
            is_admin: from.is_admin,
            is_active: from.is_active,
            availability: from.availability,
        }
    }
}
pub struct StandardFormFormFields {
    pub title_input: gpui::Entity<gpui_component::input::InputState>,
    pub count_number_input: gpui::Entity<gpui_component::input::InputState>,
    pub availability_date_picker: gpui::Entity<
        gpui_component::date_picker::DatePickerState,
    >,
}
pub struct StandardFormFormComponents;
impl StandardFormFormComponents {
    pub fn title_input(
        window: &mut gpui::Window,
        cx: &mut gpui::Context<'_, gpui_component::input::InputState>,
    ) -> gpui_component::input::InputState {
        gpui_component::input::InputState::new(window, cx)
    }
    pub fn count_number_input(
        window: &mut gpui::Window,
        cx: &mut gpui::Context<'_, gpui_component::input::InputState>,
    ) -> gpui_component::input::InputState {
        gpui_component::input::InputState::new(window, cx)
            .validate(|value, _| value.parse::<i64>().is_ok())
    }
    pub fn availability_date_picker(
        window: &mut gpui::Window,
        cx: &mut gpui::Context<'_, gpui_component::date_picker::DatePickerState>,
    ) -> gpui_component::date_picker::DatePickerState {
        gpui_component::date_picker::DatePickerState::new(window, cx)
    }
}
/// Struct tracking which form fields have errors.
#[derive(Clone, Debug)]
pub struct StandardFormFormItemsErrors {
    pub title: String,
    pub count: String,
    pub is_admin: String,
    pub is_active: String,
    pub availability: String,
}
impl Default for StandardFormFormItemsErrors {
    fn default() -> Self {
        Self {
            title: String::new(),
            count: String::new(),
            is_admin: String::new(),
            is_active: String::new(),
            availability: String::new(),
        }
    }
}
impl StandardFormFormItemsErrors {
    /// Returns true if any field has an error
    pub fn has_errors(&self) -> bool {
        !self.title.is_empty() || !self.count.is_empty() || !self.is_admin.is_empty()
            || !self.is_active.is_empty() || !self.availability.is_empty()
    }
    /// Clears all errors
    pub fn clear(&mut self) {
        *self = Self::default();
    }
}
