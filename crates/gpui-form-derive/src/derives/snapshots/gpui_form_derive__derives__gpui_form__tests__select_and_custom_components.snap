#[derive(Clone, Debug)]
pub struct AdvancedFormFormValueHolder {
    pub country: Country,
    pub language: Language,
    pub bio: Option<ExtraFancyValue>,
}
impl Default for AdvancedFormFormValueHolder {
    fn default() -> Self {
        Self {
            country: Default::default(),
            language: Default::default(),
            bio: None,
        }
    }
}
impl From<AdvancedForm> for AdvancedFormFormValueHolder {
    fn from(from: AdvancedForm) -> Self {
        Self {
            country: from.country,
            language: from.language,
            bio: from.bio,
        }
    }
}
impl From<AdvancedFormFormValueHolder> for AdvancedForm {
    fn from(from: AdvancedFormFormValueHolder) -> Self {
        Self {
            country: from.country,
            language: from.language,
            bio: from.bio,
        }
    }
}
pub struct AdvancedFormFormFields {
    pub country_select: gpui::Entity<
        gpui_component::select::SelectState<
            gpui_component::select::SearchableVec<Country>,
        >,
    >,
    pub language_select: gpui::Entity<
        gpui_component::select::SelectState<Vec<Language>>,
    >,
}
pub struct AdvancedFormFormComponents;
impl AdvancedFormFormComponents {
    pub fn country_select(
        window: &mut gpui::Window,
        cx: &mut gpui::Context<
            '_,
            gpui_component::select::SelectState<
                gpui_component::select::SearchableVec<Country>,
            >,
        >,
    ) -> gpui_component::select::SelectState<
        gpui_component::select::SearchableVec<Country>,
    > {
        use strum::IntoEnumIterator as _;
        gpui_component::select::SelectState::new(
            Country::iter().collect::<Vec<Country>>().into(),
            Some(
                gpui_component::IndexPath::new(
                    Country::iter().position(|x| x == Country::France).unwrap(),
                ),
            ),
            window,
            cx,
        )
    }
}
/// Struct tracking which form fields have errors.
#[derive(Clone, Debug)]
pub struct AdvancedFormFormItemsErrors {
    pub country: String,
    pub language: String,
    pub bio: String,
}
impl Default for AdvancedFormFormItemsErrors {
    fn default() -> Self {
        Self {
            country: String::new(),
            language: String::new(),
            bio: String::new(),
        }
    }
}
impl AdvancedFormFormItemsErrors {
    /// Returns true if any field has an error
    pub fn has_errors(&self) -> bool {
        !self.country.is_empty() || !self.language.is_empty() || !self.bio.is_empty()
    }
    /// Clears all errors
    pub fn clear(&mut self) {
        *self = Self::default();
    }
}
